def compute_class_weights(y):
    """
    Compute class weights for imbalanced dataset.
    
    For binary classification:
    - w_pos (minority) = n_majority / n_minority  
    - w_neg (majority) = 1.0
    
    This ensures equal weighted contribution: w_pos * n_minority = w_neg * n_majority
    """
    unique_labels, counts = np.unique(y, return_counts=True)
    label_counts = dict(zip(unique_labels, counts))
    
    # In your case: 0=healthy (118, minority), 1=diseased (664, majority)
    n_healthy = label_counts.get(0, 0)  # minority
    n_diseased = label_counts.get(1, 0)  # majority
    
    if n_healthy == 0 or n_diseased == 0:
        return {0: 1.0, 1: 1.0}
    
    # Calculate weights according to the paper's formula
    if n_healthy < n_diseased:  # healthy is minority
        w_healthy = n_diseased / n_healthy  # w_pos = n_neg_bal / n_pos_bal
        w_diseased = 1.0  # w_neg = 1.0
        minority_class, majority_class = 0, 1
    else:  # diseased is minority
        w_diseased = n_healthy / n_diseased
        w_healthy = 1.0
        minority_class, majority_class = 1, 0
    
    class_weights = {0: w_healthy, 1: w_diseased}
    
    print(f\"Class distribution: healthy={n_healthy}, diseased={n_diseased}\")
    print(f\"Minority class: {minority_class} (count: {min(n_healthy, n_diseased)})\")\n    print(f\"Majority class: {majority_class} (count: {max(n_healthy, n_diseased)})\")\n    print(f\"Class weights: {class_weights}\")\n    \n    # Verification\n    weighted_healthy = class_weights[0] * n_healthy\n    weighted_diseased = class_weights[1] * n_diseased\n    print(f\"Weighted contributions: healthy={weighted_healthy:.1f}, diseased={weighted_diseased:.1f}\")\n    \n    return class_weights\n\ndef create_sample_weights(y, class_weights):\n    \"\"\"\n    Create sample weights array for sklearn classifiers.\n    \"\"\"\n    sample_weights = np.array([class_weights[label] for label in y])\n    return sample_weights# COPY AND PASTE THIS CODE TO REPLACE YOUR EXISTING CLASSIFIER TRAINING SECTION
