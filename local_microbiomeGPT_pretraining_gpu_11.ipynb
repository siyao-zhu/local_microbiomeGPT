# Since we're using sklearn, we'll simulate balanced sampling by creating balanced mini-batches

import numpy as np
from sklearn.utils import resample

def create_balanced_batches(X, y, batch_size=64, random_state=42):
    """
    Create balanced mini-batches where each batch has roughly equal representation of classes.
    This simulates PyTorch's WeightedRandomSampler for sklearn.
    
    Args:
        X: Feature matrix
        y: Labels
        batch_size: Size of each batch
        random_state: Random seed
    
    Returns:
        List of (X_batch, y_batch) tuples
    """
    np.random.seed(random_state)
    
    # Separate classes
    unique_classes = np.unique(y)
    class_indices = {cls: np.where(y == cls)[0] for cls in unique_classes}
    
    print(f"Class distribution in original data:")
    for cls in unique_classes:
        print(f"  Class {cls}: {len(class_indices[cls])} samples")
    
    # Calculate samples per class per batch (aim for balanced batches)
    samples_per_class_per_batch = batch_size // len(unique_classes)
    remainder = batch_size % len(unique_classes)
    
    print(f"Target per batch: {samples_per_class_per_batch} samples per class")
    
    # Create balanced batches
    batches = []
    total_samples = len(X)
    num_batches = (total_samples + batch_size - 1) // batch_size  # Ceiling division
    
    for batch_idx in range(num_batches):
        batch_X_list = []
        batch_y_list = []
        
        for cls_idx, cls in enumerate(unique_classes):
            # Number of samples for this class in this batch
            n_samples = samples_per_class_per_batch
            if cls_idx < remainder:  # Distribute remainder
                n_samples += 1
            
            # Sample with replacement from this class
            cls_sample_indices = np.random.choice(
                class_indices[cls], 
                size=n_samples, 
                replace=True  # Allow replacement for minority class
            )
            
            batch_X_list.append(X[cls_sample_indices])
            batch_y_list.append(y[cls_sample_indices])
        
        # Combine all classes for this batch
        batch_X = np.vstack(batch_X_list)
        batch_y = np.hstack(batch_y_list)
        
        # Shuffle within batch
        batch_indices = np.random.permutation(len(batch_X))
        batch_X = batch_X[batch_indices]
        batch_y = batch_y[batch_indices]
        
        batches.append((batch_X, batch_y))
    
    print(f"Created {len(batches)} balanced batches")
    return batches

def compute_sample_weights_inverse_frequency(y):
    """
    Compute inverse-frequency weights per sample (as described in Strategy 3).
    
    For each sample i: w_i = 1.0 / class_count[class_of_sample_i]
    """
    unique_classes, class_counts = np.unique(y, return_counts=True)
    class_count_dict = dict(zip(unique_classes, class_counts))
    
    # Compute weight for each sample
    sample_weights = np.array([1.0 / class_count_dict[label] for label in y])
    
    print(f"Inverse-frequency sample weights:")
    for cls in unique_classes:
        weight = 1.0 / class_count_dict[cls]
        count = class_count_dict[cls]
        print(f"  Class {cls}: weight={weight:.6f} (count={count})")
        print(f"    Probability boost: {weight * count:.1f}x")
    
    return sample_weights, class_count_dict# Compare Strategy 1 vs Strategy 2 Results
